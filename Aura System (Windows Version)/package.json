{
  "name": "aura-system-windows",
  "version": "1.0.0",
  "description": "Versao Desktop do Aura System Offline-First",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "start": "electron .",
    "build": "echo 'Build skip - using pre-built or source'",
    "dist": "electron-builder"
  },
  "author": "Aura System",
  "build": {
    "appId": "com.aura.system",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "icon": "public/favicon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "dist/**/*",
      "main.js",
      "package.json",
      "public/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^40.6.1",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "better-sqlite3": "^12.6.2",
    "drizzle-orm": "^0.39.3",
    "electron-updater": "^6.8.3",
    "express": "^4.21.2",
    "tsx": "^4.21.0"
  }
}
